{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.8",
        "laravel/framework": "^11.0",
        "laravel/tinker": "^2.9",
        "league/csv": "^9.15",
        "livewire/livewire": "^3.4",
        "lorisleiva/laravel-actions": "^2.8",
        "openai-php/laravel": "^0.8.1",
        "probots-io/pinecone-php": "^1.0",
        "spatie/pdf-to-text": "^1.52"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.0",
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^10.5",
        "spatie/laravel-ignition": "^2.4"
    },
    "autoload": {
        "files": [
            "resources/helpers.php"
        ],
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:meta",
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "audit": {
            "ignore": {
                "PKSA-mdq4-51ck-6kdq": "Laravel CRLF email rule fix requires Laravel 12; tracked for separate major upgrade",
                "PKSA-8qx3-n5y5-vvnd": "Laravel framework advisory; fix requires Laravel 12 upgrade",
                "PKSA-q46n-4fdk-zjr4": "Laravel framework advisory; fix requires Laravel 12 upgrade",
                "PKSA-qzrn-rnz3-85w1": "Laravel framework advisory; fix requires Laravel 12 upgrade",
                "PKSA-w7xr-vk7n-rstm": "Laravel framework advisory; fix requires Laravel 12 upgrade",
                "PKSA-xnj5-w74d-6wmz": "Saloon fix requires v4; blocked by probots-io/pinecone-php pinning saloon ^3.6",
                "PKSA-rnpm-45mg-w6ht": "Saloon fix requires v4; blocked by probots-io/pinecone-php pinning saloon ^3.6",
                "PKSA-5szq-gvrg-ttfq": "Saloon fix requires v4; blocked by probots-io/pinecone-php pinning saloon ^3.6"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
